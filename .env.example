# MongoDB připojení
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# JWT autentifikace (min. 32 náhodných znaků)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Resend (emailové notifikace)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Pionýr Pacov <noreply@vase-domena.cz>

# Příjemci emailových notifikací
NOTIFICATION_EMAIL=admin@vase-domena.cz
NOTIFICATION_EMAIL_2=admin2@vase-domena.cz   # volitelné

# Veřejná URL (pro odkazy v emailech)
NEXT_PUBLIC_BASE_URL=https://pionyrtaborpacov.cz
